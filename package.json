{
	"type": "module",
	"private": true,
	"license": "MIT",
	"description": "HTML tags, just truly accessible",
	"workspaces": [
		"packages/*"
	],
	"homepage": "https://u-elements.github.io/u-elements/",
	"repository": {
		"type": "git",
		"url": "https://github.com/u-elements/u-elements.git"
	},
	"bugs": {
		"url": "https://github.com/u-elements/u-elements/issues"
	},
	"scripts": {
		"build": "npm run build --workspaces",
		"docs:build": "npm run build && vitepress build docs",
		"docs:dev": "vitepress dev docs",
		"docs:preview": "vitepress preview docs",
		"lint": "npx @biomejs/biome check",
		"prepublishOnly": "npm run build",
		"dev:build": "vite build",
		"dev": "vite",
		"dev:preact": "vite --config=frameworks/preact/vite.config.ts",
		"dev:qwik": "vite --config=frameworks/qwik/vite.config.ts",
		"dev:react": "vite --config=frameworks/react/vite.config.ts",
		"dev:solid": "vite --config=frameworks/solid/vite.config.ts",
		"dev:svelte": "vite --config=frameworks/svelte/vite.config.ts",
		"dev:vue": "vite --config=frameworks/vue/vite.config.ts",
		"test": "playwright test",
		"test:update": "npm run test -- --update-snapshots"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@custom-elements-manifest/analyzer": "0.11.0",
		"@mdn/browser-compat-data": "8.0.1",
		"@playwright/test": "1.60.0",
		"@preact/preset-vite": "2.10.5",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tsconfig/svelte": "5.0.8",
		"@types/caniuse-lite": "1.0.5",
		"@types/node": "25.9.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"@vitejs/plugin-vue": "6.0.7",
		"@vue/runtime-dom": "3.5.35",
		"caniuse-lite": "1.0.30001793",
		"custom-element-vs-code-integration": "1.5.0",
		"jshint": "2.13.6",
		"prettier": "3.8.3",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"solid-js": "1.9.13",
		"svelte": "5.56.2",
		"svelte-check": "4.6.0",
		"tslib": "2.8.1",
		"tsup": "8.5.1",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vite-plugin-cem": "0.8.5",
		"vite-plugin-solid": "2.11.12",
		"vitepress": "2.0.0-alpha.17",
		"vue": "3.5.35",
		"vue-tsc": "3.3.3"
	},
	"overrides": {
		"ansi-regex": "^6.2.2",
		"ansi-styles": "^6.2.3",
		"chalk": "^5.6.2",
		"debug": "^4.4.3",
		"esbuild": "^0.27.0",
		"glob": "^13.0.6",
		"lodash": "^4.18.1",
		"minimatch": "^10.2.5",
		"seroval": "^1.4.1",
		"strip-ansi": "^7.1.2",
		"supports-color": "^10.2.2",
		"tmp": "^0.2.5",
		"wrap-ansi": "^9.0.1"
	}
}
